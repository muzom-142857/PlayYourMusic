# ─── Database (Railway PostgreSQL) ──────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
AUTH_URL="http://localhost:3000"
AUTH_SECRET=""  # openssl rand -base64 32
AUTH_TRUST_HOST="true"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Spotify OAuth ────────────────────────────────────────────────────────────
# https://developer.spotify.com/dashboard
# Redirect URI: http://localhost:3000/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# ─── Apple OAuth ──────────────────────────────────────────────────────────────
# https://developer.apple.com/account/ → Certificates, Identifiers & Profiles
APPLE_CLIENT_ID=""        # Services ID (e.g., com.yourapp.web)
APPLE_CLIENT_SECRET=""    # JWT signed with private key (use next-auth helper)
APPLE_TEAM_ID=""
APPLE_KEY_ID=""

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# https://github.com/settings/applications/new
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="playyourmusic"
# Public domain for R2 bucket (or r2.dev subdomain)
CLOUDFLARE_R2_PUBLIC_URL="https://assets.playyourmusic.com"
# Same value as above but exposed to the browser for client-side upload URLs
NEXT_PUBLIC_R2_PUBLIC_URL="https://assets.playyourmusic.com"

# ─── YouTube Data API v3 ──────────────────────────────────────────────────────
# https://console.cloud.google.com/ → APIs → YouTube Data API v3
YOUTUBE_API_KEY=""
