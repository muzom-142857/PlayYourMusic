// PlayYourMusic — Prisma Schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Platform {
  YOUTUBE
  SPOTIFY
  APPLE_MUSIC
  SOUNDCLOUD
  OTHER
}

// ─── User & Auth ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  username  String   @unique
  avatarUrl String?  @map("avatar_url")
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts  Account[]
  sessions  Session[]
  playlists Playlist[]
  likes     PlaylistLike[]
  comments  PlaylistComment[]
  followers Follow[]         @relation("Following")
  following Follow[]         @relation("Follower")
  history   ListeningHistory[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Social ──────────────────────────────────────────────────────────────────

model Follow {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

// ─── Playlist ────────────────────────────────────────────────────────────────

model Playlist {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverUrl    String?  @map("cover_url")
  // Cached palette from node-vibrant: { primary, secondary, muted, vibrant }
  coverColors Json?    @map("cover_colors")
  isPublic    Boolean  @default(true) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tracks     Track[]
  likes      PlaylistLike[]
  comments   PlaylistComment[]
  tags       Tag[]      @relation("PlaylistTags")
  categories Category[] @relation("PlaylistCategories")
  history    ListeningHistory[]

  // Denormalized counts (updated via increment/decrement) for fast sorting
  likeCount  Int @default(0) @map("like_count")
  playCount  Int @default(0) @map("play_count")
  trackCount Int @default(0) @map("track_count")

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([likeCount(sort: Desc)])
  @@index([isPublic, createdAt(sort: Desc)])
  @@map("playlists")
}

model Track {
  id             String   @id @default(cuid())
  title          String
  artist         String?
  duration       Int?     // seconds
  sourceUrl      String   @map("source_url")
  sourcePlatform Platform @map("source_platform")
  thumbnailUrl   String?  @map("thumbnail_url")
  position       Int      // order within playlist

  playlistId String   @map("playlist_id")
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, position])
  @@map("tracks")
}

// ─── Interactions ─────────────────────────────────────────────────────────────

model PlaylistLike {
  userId     String   @map("user_id")
  playlistId String   @map("playlist_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([userId, playlistId])
  @@map("playlist_likes")
}

model PlaylistComment {
  id         String   @id @default(cuid())
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  userId     String @map("user_id")
  playlistId String @map("playlist_id")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([playlistId, createdAt(sort: Desc)])
  @@map("playlist_comments")
}

// ─── Taxonomy ─────────────────────────────────────────────────────────────────

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  playlists Playlist[] @relation("PlaylistTags")

  @@map("tags")
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  emoji       String?
  description String?
  sortOrder   Int        @default(0) @map("sort_order")
  playlists   Playlist[] @relation("PlaylistCategories")

  @@map("categories")
}

// ─── Listening History (for recommendations) ──────────────────────────────────

model ListeningHistory {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  playlistId String   @map("playlist_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([playlistId])
  @@map("listening_history")
}
